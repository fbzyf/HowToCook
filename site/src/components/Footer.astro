---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <p class="footer-tagline">清晰精准，像写代码一样做饭</p>
    <p class="footer-copy">
      基于 <a href="https://github.com/Anduin2017/HowToCook" target="_blank" rel="noopener">HowToCook</a> 开源菜谱 · {year}
    </p>
  </div>
</footer>

<style>
  .footer {
    margin-top: 4rem;
    padding: 2.5rem 0;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-muted);
    text-align: center;
  }

  .footer-tagline {
    font-family: var(--font-serif);
    color: var(--color-text-muted);
    margin: 0 0 0.5rem;
  }

  .footer-copy {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
