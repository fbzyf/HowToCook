---
import Layout from '../../layouts/Layout.astro';
import { withBase } from '../../lib/paths';
import { getAllTips, getTipBySlug } from '../../lib/tips';

export function getStaticPaths() {
  return getAllTips().map((tip) => ({
    params: { slug: tip.slug },
  }));
}

const { slug } = Astro.params;

const tip = getTipBySlug(slug ?? '');

if (!tip) {
  return Astro.redirect(withBase('tips'));
}
---

<Layout title={tip.title} description={`${tip.groupTitle} — ${tip.title}`}>
  <article class="container tip-page">
    <nav class="breadcrumb">
      <a href={withBase('')}>首页</a>
      <span class="breadcrumb-sep">/</span>
      <a href={withBase('tips')}>烹饪技巧</a>
      <span class="breadcrumb-sep">/</span>
      <span>{tip.title}</span>
    </nav>

    <header class="page-header">
      <span class="badge badge-primary">{tip.groupTitle}</span>
      <h1>{tip.title}</h1>
    </header>

    <div class="prose" set:html={tip.contentHtml} />
  </article>
</Layout>

<style>
  .tip-page {
    padding-bottom: 3rem;
  }

  .tip-page .page-header {
    padding-top: 1rem;
  }
</style>
